# NeuroHire Environment Variables Configuration
# Set MOCK_MODE to true to run everything with mock data and templates (default: true)
MOCK_MODE=true

# Optional live integrations (needed when MOCK_MODE=false)
# GITHUB_TOKEN=your_github_token_here
# GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
# GITHUB_MODEL_NAME=gpt-4o
# FIRECRAWL_API_KEY=your_firecrawl_key_here
# SUPABASE_URL=your_supabase_url_here
# SUPABASE_KEY=your_supabase_anon_key_here
# QDRANT_URL=your_qdrant_url_here
# QDRANT_API_KEY=your_qdrant_key_here
# UPSTASH_REDIS_URL=your_redis_url_here
