/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hirehawk-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-15",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	/**
	 * D1 Database for user authentication
	 */
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "hirehawk-auth",
			"database_id": "4fd3ffdc-3174-42a7-955f-4f3fd23e2368"
		}
	],
	/**
	 * Environment Variables (non-secret, used in production)
	 * Secrets (GEMINI_API_KEY, SUPABASE_KEY) are set via:
	 *   npx wrangler secret put GEMINI_API_KEY
	 *   npx wrangler secret put SUPABASE_KEY
	 */
	"vars": {
		"GEMINI_MOCK": "true",
		"SUPABASE_MOCK": "true"
	}
	/**
	 * To enable agentic backend, set AGENT_BACKEND_URL as a secret:
	 *   npx wrangler secret put AGENT_BACKEND_URL
	 * Then set value to your Render URL, e.g.:
	 *   https://hirehawk-agent.onrender.com
	 */
}